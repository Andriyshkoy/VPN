# PostgreSQL settings
POSTGRES_DB=vpn
POSTGRES_USER=vpn
POSTGRES_PASSWORD=vpn

# Production Compose only: use a URL-safe generated password (for example,
# `openssl rand -hex 32`). Production Compose constructs REDIS_URL from it;
# local Compose remains passwordless.
REDIS_PASSWORD=

# Application settings (used by Docker Compose)
DATABASE_URL=postgresql+asyncpg://vpn:vpn@db:5432/vpn
# Generate once with the Fernet command in README.md; keep it stable.
ENCRYPTION_KEY=change_me
BOT_TOKEN=change_me
TELEGRAM_PAY_TOKEN=
PER_CONFIG_COST=1.00
CONFIG_CREATION_COST=10.00
BILLING_INTERVAL=3600
MAINTENANCE_MODE=false
BILLING_ENABLED=true
PROVISIONING_ENABLED=true
NOTIFICATIONS_ENABLED=true
NOTIFICATION_MAX_ATTEMPTS=10
NOTIFICATION_VISIBILITY_TIMEOUT=120
NOTIFICATION_DEDUPE_TTL_SECONDS=86400
PAYMENT_INTENT_TTL_SECONDS=3600
# 500/100 basis points = 5% for the direct referrer and 1% for level two.
REFERRAL_REWARDS_ENABLED=true
REFERRAL_LEVEL_1_RATE_BPS=500
REFERRAL_LEVEL_2_RATE_BPS=100
REFERRAL_PROGRAM_VERSION=v1-5pct-1pct
VPN_OPERATION_MAX_ATTEMPTS=20
# Legacy Manager HTTP remains the default. Mount CA/client identity into the
# directory below before enabling TLS; leave client cert/key blank for HTTPS
# without mutual TLS.
VPN_MANAGER_TLS_ENABLED=false
VPN_MANAGER_MTLS_REQUIRED=false
VPN_MANAGER_TLS_PORT=16291
VPN_MANAGER_TLS_DIR=./secrets/vpn-manager
# Separate production host path: copied local environments must not override it.
VPN_MANAGER_TLS_DIR_PROD=/etc/vpn-hub/manager-pki
VPN_MANAGER_CA_CERT_PATH=/run/secrets/vpn-manager/ca.crt
VPN_MANAGER_CLIENT_CERT_PATH=/run/secrets/vpn-manager/client.crt
VPN_MANAGER_CLIENT_KEY_PATH=/run/secrets/vpn-manager/client.key
# Read-only drift audit is always safe; mutation requires this explicit gate.
VPN_DRIFT_REPAIR_ENABLED=false
# Incoming Telegram updates are committed to PostgreSQL before getUpdates ACK.
TELEGRAM_UPDATE_POLL_TIMEOUT=30
TELEGRAM_UPDATE_BATCH_SIZE=100
# Bounded parallelism across independent chat/user ordering lanes.
TELEGRAM_UPDATE_PROCESSOR_COUNT=4
TELEGRAM_UPDATE_LEASE_SECONDS=300
# Must remain shorter than TELEGRAM_UPDATE_LEASE_SECONDS.
TELEGRAM_UPDATE_HANDLER_TIMEOUT_SECONDS=240
TELEGRAM_UPDATE_MAX_ATTEMPTS=20
TELEGRAM_UPDATE_RETRY_MAX_SECONDS=300
TELEGRAM_UPDATE_RETENTION_DAYS=30
# Must remain shorter than TELEGRAM_UPDATE_RETENTION_DAYS.
TELEGRAM_UPDATE_DEAD_RETENTION_DAYS=7
# Best-effort StatsD emission. Local Compose overrides this to true per service.
OBSERVABILITY_ENABLED=false
STATSD_HOST=statsd_exporter
STATSD_PORT=9125
VPN_HUB_SERVICE=unknown
READINESS_TIMEOUT_SECONDS=2.0
SQL_ECHO=false
ADMIN_USERNAME=admin
# Generate with the bcrypt command documented in README.md.
ADMIN_PASSWORD_HASH=
REDIS_URL=redis://redis:6379/0

# Production release artifacts. Replace every `unreleased` value with an
# immutable commit tag or, preferably, a full registry name@sha256 digest.
VPN_MIGRATIONS_IMAGE=andriyshkoy/vpn-migrations:unreleased
VPN_ADMIN_IMAGE=andriyshkoy/vpn-admin:unreleased
VPN_BOT_IMAGE=andriyshkoy/vpn-bot:unreleased
VPN_BILLING_IMAGE=andriyshkoy/vpn-billing:unreleased
VPN_ADMIN_FRONTEND_IMAGE=andriyshkoy/vpn-admin-frontend:unreleased
VPN_NGINX_IMAGE=andriyshkoy/vpn-nginx:unreleased
POSTGRES_EXPORTER_USER=
POSTGRES_EXPORTER_PASSWORD=

# Browser-visible API origin for the local admin frontend
VITE_ADMIN_API_URL=http://localhost:14081
